{
  "name": "@lafken/state-machine",
  "version": "0.8.0",
  "private": false,
  "description": "Build Step Functions workflows with TypeScript decorators - declarative orchestration with Lafken",
  "keywords": [
    "aws",
    "step functions",
    "state machine",
    "workflow",
    "orchestration",
    "serverless",
    "typescript",
    "decorators",
    "lafken"
  ],
  "homepage": "https://github.com/Hero64/lafken#readme",
  "bugs": "https://github.com/Hero64/lafken/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hero64/lafken",
    "directory": "packages/state-machine"
  },
  "license": "MIT",
  "author": "Aníbal Jorquera",
  "exports": {
    "./main": {
      "import": "./lib/main/index.js",
      "types": "./lib/main/index.d.ts",
      "require": "./lib/main/index.js"
    },
    "./resolver": {
      "import": "./lib/resolver/index.js",
      "types": "./lib/resolver/index.d.ts",
      "require": "./lib/resolver/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "main": [
        "./lib/main/index.d.ts"
      ],
      "resolver": [
        "./lib/resolver/index.d.ts"
      ]
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p ./tsconfig.build.json",
    "check-types": "tsc --noEmit -p ./tsconfig.build.json",
    "clean": "rm -rf ./lib",
    "dev": "tsc -w",
    "prepublishOnly": "pnpm build",
    "test": "vitest"
  },
  "dependencies": {
    "@lafken/resolver": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@cdktn/provider-aws": "^23.3.0",
    "@lafken/common": "workspace:*",
    "@swc/core": "^1.15.18",
    "@swc/helpers": "^0.5.19",
    "@vitest/runner": "^4.1.0",
    "cdktn": "^0.22.0",
    "cdktn-vitest": "^1.0.0",
    "constructs": "^10.5.1",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@cdktn/provider-aws": "^23.0.0",
    "@lafken/common": "^0.7.0",
    "cdktn": "^0.22.0",
    "constructs": "^10.4.5"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
