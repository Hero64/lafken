{
  "name": "@lafken/auth",
  "version": "0.13.0",
  "private": false,
  "description": "Define Cognito User Pools using TypeScript decorators - simplified authentication infrastructure with Lafken",
  "keywords": [
    "aws",
    "cognito",
    "auth",
    "authentication",
    "identity",
    "serverless",
    "typescript",
    "decorators",
    "lafken"
  ],
  "homepage": "https://github.com/Hero64/lafken#readme",
  "bugs": "https://github.com/Hero64/lafken/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hero64/lafken",
    "directory": "packages/auth"
  },
  "license": "MIT",
  "author": "Aníbal Jorquera",
  "exports": {
    "./main": {
      "types": "./lib/main/index.d.ts",
      "import": "./lib/main/index.js",
      "require": "./lib/main/index.js"
    },
    "./resolver": {
      "types": "./lib/resolver/index.d.ts",
      "import": "./lib/resolver/index.js",
      "require": "./lib/resolver/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "main": [
        "./lib/main/index.d.ts"
      ],
      "resolver": [
        "./lib/resolver/index.d.ts"
      ]
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p ./tsconfig.build.json",
    "check-types": "tsc --noEmit -p ./tsconfig.build.json",
    "clean": "rm -rf ./lib",
    "dev": "tsc -w",
    "prepublishOnly": "pnpm build",
    "test": "vitest"
  },
  "dependencies": {
    "@lafken/resolver": "workspace:*",
    "reflect-metadata": "catalog:"
  },
  "devDependencies": {
    "@cdktn/provider-aws": "catalog:",
    "@lafken/common": "workspace:*",
    "@swc/core": "catalog:",
    "@swc/helpers": "catalog:",
    "@vitest/runner": "catalog:",
    "cdktn": "catalog:",
    "cdktn-vitest": "catalog:",
    "constructs": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@cdktn/provider-aws": ">=23.0.0",
    "@lafken/common": "workspace:*",
    "cdktn": ">=0.22.0",
    "constructs": "^10.4.5"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
