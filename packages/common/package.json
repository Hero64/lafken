{
  "name": "@lafken/common",
  "version": "0.13.0",
  "private": false,
  "description": "Lafken utilities - TypeScript decorator factories and metadata reflection for infrastructure-as-code decorators",
  "keywords": [
    "aws",
    "serverless",
    "lafken",
    "decorators",
    "metadata",
    "reflection",
    "typescript",
    "utility"
  ],
  "homepage": "https://github.com/Hero64/lafken#readme",
  "bugs": "https://github.com/Hero64/lafken/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hero64/lafken",
    "directory": "packages/common"
  },
  "license": "MIT",
  "author": "Aníbal Jorquera",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "pnpm clean && tsc -p ./tsconfig.build.json",
    "check-types": "tsc --noEmit -p ./tsconfig.build.json",
    "clean": "rm -rf ./lib",
    "dev": "tsc -w",
    "prepublishOnly": "pnpm build",
    "test": "vitest"
  },
  "dependencies": {
    "@types/aws-lambda": "catalog:",
    "reflect-metadata": "catalog:"
  },
  "devDependencies": {
    "@swc/core": "catalog:",
    "@swc/helpers": "catalog:",
    "@vitest/runner": "catalog:",
    "cdktn-vitest": "catalog:",
    "typescript": "catalog:",
    "unplugin-swc": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19"
  },
  "publishConfig": {
    "access": "public"
  }
}
