{
  "name": "lafken",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "pnpm biome format --write . ",
    "lint": "turbo run lint",
    "modules:clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf {} +",
    "prepare": "husky",
    "release": "turbo run build && pnpm -r publish --access public --no-git-checks",
    "test": "turbo run test --concurrency=4",
    "update-version": "node scripts/version.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "26.1.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "turbo": "2.10.5",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@10.29.3"
}
