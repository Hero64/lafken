{
  "name": "lafken",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "pnpm biome format --write . ",
    "lint": "turbo run lint",
    "modules:clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf {} +",
    "prepare": "husky",
    "release": "turbo run build && pnpm -r publish --access public --no-git-checks",
    "test": "turbo run test --concurrency=4",
    "update-version": "node scripts/version.js"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@types/node": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@10.29.3"
}
